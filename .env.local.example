# Copy to .env.local and fill with your Supabase project's values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used for privileged actions (creating team-member accounts).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only. Sarvam AI key (sk_...) for call transcription + summary.
# Indian-language ASR (Punjabi / Hindi / code-mixed). Get one at sarvam.ai.
# Recording/upload/playback work without it; auto-transcription needs it.
SARVAM_API_KEY=your-sarvam-api-key

# Demo mode: shows the login role buttons + the in-app "switch role" dropdown
# that re-authenticates as the seeded demo accounts. Turn OFF in production.
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_PASSWORD=password123
